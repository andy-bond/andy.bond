{
  "name": "andy.bond",
  "version": "0.0.1",
  "description": "Personal website & blog of Andy Bond.",
  "homepage": "https://github.com/andy-bond/andy.bond#readme",
  "license": "MIT",
  "repository": "github:andy-bond/andy.bond",
  "scripts": {
    "start": "npm-run-all build:sass --parallel watch:*",
    "build": "npm-run-all build:sass build:eleventy",
    "watch:sass": "sass --no-source-map --watch src/static/scss:_site/static/css",
    "watch:eleventy": "eleventy --serve",
    "build:sass": "sass --no-source-map src/static/scss:_site/static/css",
    "build:eleventy": "eleventy",
    "postbuild": "postcss _site/static/css/*.css -u autoprefixer cssnano -r --no-map",
    "cms": "npx netlify-cms-proxy-server"
  },
  "devDependencies": {
    "@11ty/eleventy": "^1.0.0-beta.2",
    "@11ty/eleventy-img": "^1.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^3.1.3",
    "autoprefixer": "^10.3.7",
    "browser-sync": "^2.27.5",
    "cross-env": "^7.0.3",
    "cssnano": "^5.0.8",
    "feather-icons": "^4.28.0",
    "html-minifier": "^4.0.0",
    "lodash": "^4.17.21",
    "lucide": "^0.16.20",
    "lucide-static": "^0.16.19-rc.0",
    "luxon": "^2.0.2",
    "netlify-plugin-11ty": "^1.1.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.3.9",
    "postcss-cli": "^9.0.1",
    "prismjs": "^1.25.0",
    "sass": "^1.42.1"
  },
  "browserslist": [
    "last 2 versions"
  ]
}
