{
  "name": "andy.bond",
  "version": "0.0.1",
  "description": "Personal website & blog of Andy Bond.",
  "homepage": "https://github.com/andy-bond/andy.bond#readme",
  "license": "MIT",
  "repository": "github:andy-bond/andy.bond",
  "scripts": {
    "start": "npm-run-all build:sass --parallel watch:*",
    "cms": "npx netlify-cms-proxy-server",
    "build": "npm-run-all build:sass build:eleventy",
    "watch:sass": "sass --no-source-map --watch src/static/scss:_site/static/css",
    "watch:eleventy": "eleventy --serve",
    "build:sass": "sass --no-source-map src/static/scss:_site/static/css",
    "build:eleventy": "eleventy",
    "postbuild": "postcss _site/static/css/*.css -u autoprefixer cssnano -r --no-map",
    "lint:prettier": "prettier --list-different \"./**/*{.html,.ts,.js,.json,.css,.scss}\"",
    "fix:prettier": "prettier --write \"./**/*{.html,.ts,.js,.json,.css,.scss}\""
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.0-canary.11",
    "@11ty/eleventy-img": "^2.0.1",
    "@11ty/eleventy-plugin-syntaxhighlight": "^4.0.0",
    "autoprefixer": "^10.4.7",
    "cross-env": "^7.0.3",
    "cssnano": "^5.1.11",
    "eslint": "^8.17.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.26.0",
    "html-minifier": "^4.0.0",
    "lucide-static": "^0.41.0",
    "luxon": "^2.4.0",
    "netlify-plugin-11ty": "^1.1.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.14",
    "postcss-cli": "^9.1.0",
    "prettier": "^2.6.2",
    "prismjs": "^1.28.0",
    "sass": "^1.52.3"
  },
  "browserslist": [
    "last 2 versions"
  ]
}
